    "from skmultiflow.data import AnomalySineGenerator\n",
    "from skmultiflow.anomaly_detection import HalfSpaceTrees\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import precision_score, recall_score, f1_score\n",
    "\n",
    "\n",
    "stream = AnomalySineGenerator()\n",
    "\n",
    "\n",
    "model = HalfSpaceTrees(\n",
    "    anomaly_threshold=0.98,\n",
    "    window_size=500,      # Large buffer of history\n",
    "    depth=10,             # Simpler tree\n",
    "    n_estimators=10       # Fewer trees = cleaner output\n",
    ")\n",
    "\n",
    "\n",
    "X_train, _ = stream.next_sample(300)\n",
    "model.partial_fit(X_train)\n",
    "\n",
    "\n",
    "y_true = []\n",
    "y_pred = []\n",
    "\n",
    "for _ in range(400):\n",
    "    X, y = stream.next_sample()\n",
    "    pred = model.predict(X)\n",
    "    model.partial_fit(X)\n",
    "    y_pred.append(pred[0])\n",
    "    y_true.append(y[0])\n",
    "\n",
    "# 5. Double smoothing logic (5-sample window, at least 3 anomalies in group)\n",
    "smoothed_pred = []\n",
    "for i in range(len(y_pred)):\n",
    "    window = y_pred[max(0, i-2):min(len(y_pred), i+3)]\n",
    "    if y_pred[i] == 1 and sum(window) >= 3:\n",
    "        smoothed_pred.append(1)\n",
    "    else:\n",
    "        smoothed_pred.append(0)\n",
    "\n",
    "\n",
    "precision = precision_score(y_true, smoothed_pred)\n",
    "recall = recall_score(y_true, smoothed_pred)\n",
    "f1 = f1_score(y_true, smoothed_pred)\n",
    "\n",
    "print(f\"\\nFinal Evaluation:\")\n",
    "print(f\"Precision: {precision:.2f}\")\n",
    "print(f\"Recall:    {recall:.2f}\")\n",
    "print(f\"F1 Score:  {f1:.2f}\")\n",
    "\n",
    "\n",
    "plt.figure(figsize=(12, 4))\n",
    "plt.plot(smoothed_pred, label='Predicted Anomalies (Smoothed)', linestyle='--', color='red')\n",
    "plt.plot(y_true, label='True Anomalies', alpha=0.6, color='blue')\n",
    "plt.title(\"HalfSpaceTrees FINAL TUNED (Depth=10, Estimators=10, Window=500)\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n"
   ]
